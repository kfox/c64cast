# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
build/
dist/
.eggs/

# Coverage / test artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/
.ruff_cache/
test.toml

# Virtualenvs / package managers
.venv/
venv/
env/
.envrc
.python-version

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# Project-specific
# user config; only config/c64cast.example.toml is tracked
c64cast.toml
# diag tool captures/fixtures; the tools are tracked
scripts/diags/out/
# legacy: local stream recordings outside assets/
recordings/
*.mp4
*.mkv
*.mov
# video production planning, demo configs, and footage (uncommitted)
videos/

# Assets — only the directory READMEs are tracked. Drop your own files
# under assets/<subdir>/ and they will be ignored (most have unclear
# licensing or are personal/local).
assets/*/*
!assets/*/README.md

# Claude
.claude/

# OS
.DS_Store
Thumbs.db
