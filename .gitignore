# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
build/
dist/
.eggs/

# Coverage / test artifacts
.coverage
.coverage.*
coverage.xml
htmlcov/
test-results/
.pytest_cache/
.tox/
.ruff_cache/

# Virtualenvs / package managers
.venv/
venv/
env/
.envrc
.python-version

# Editor / IDE
.idea/
.vscode/
*.swp
*~

# Project-specific
# user-generated top-level config tomls (quick tests, scratch scene configs).
# Only real project files are tracked; put reusable configs under config/.
/*.toml
!/mise.toml
!/pyproject.toml
config/*.toml
!config/c64cast.example.toml
# diag tool captures/fixtures; the tools are tracked
scripts/diags/out/
# per-system DAC calibration tables (captured from real hardware via
# --calibrate-dac; machine-specific, not source). Only the README is tracked.
calibration/*
!calibration/README.md
# WLED presets captured from the WLED app / the `/` control page (Mode 1);
# machine/taste-specific, not source. Only the README is tracked.
presets/*
!presets/README.md
# legacy: local stream recordings outside assets/
recordings/
*.mp4
*.mkv
*.mov
# video production planning, demo configs, and footage
videos/

# Assets — only the directory READMEs are tracked. Drop your own files
# under assets/<subdir>/ and they will be ignored (most have unclear
# licensing or are personal/local).
assets/*/*
!assets/*/README.md

# Claude
.claude/

# OS
.DS_Store
Thumbs.db
